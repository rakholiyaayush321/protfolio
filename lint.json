5,24],"text":""},"desc":"Remove unused variable 'useMemo'."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useRef, useMemo } from 'react';\r\nimport { Canvas, useFrame } from '@react-three/fiber';\r\nimport { Points, PointMaterial } from '@react-three/drei';\r\nimport * as THREE from 'three';\r\n\r\nconst generateParticles = (count) => {\r\n  const array = new Float32Array(count * 3);\r\n  for (let i = 0; i < count; i++) {\r\n    const u = Math.random();\r\n    const v = Math.random();\r\n    const theta = u * 2.0 * Math.PI;\r\n    const phi = Math.acos(2.0 * v - 1.0);\r\n    const r = Math.cbrt(Math.random()) * 8; // Radius\r\n    \r\n    const x = r * Math.sin(phi) * Math.cos(theta);\r\n    const y = r * Math.sin(phi) * Math.sin(theta);\r\n    const z = r * Math.cos(phi);\r\n    \r\n    array[i * 3] = x;\r\n    array[i * 3 + 1] = y;\r\n    array[i * 3 + 2] = z;\r\n  }\r\n  return array;\r\n};\r\n\r\nconst particleData = generateParticles(2000);\r\n\r\nfunction Particles() {\r\n  const ref = useRef();\r\n  \r\n  useFrame((state, delta) => {\r\n    if (ref.current) {\r\n      ref.current.rotation.x -= delta / 10;\r\n      ref.current.rotation.y -= delta / 15;\r\n    }\r\n  });\r\n\r\n  return (\r\n    <group rotation={[0, 0, Math.PI / 4]}>\r\n      <Points ref={ref} positions={particleData} stride={3} frustumCulled={false}>\r\n        <PointMaterial\r\n          transparent\r\n          color=\"#6366f1\"\r\n          size={0.015}\r\n          sizeAttenuation={true}\r\n          depthWrite={false}\r\n          blending={THREE.AdditiveBlending}\r\n        />\r\n      </Points>\r\n    </group>\r\n  );\r\n}\r\n\r\nexport default function BackgroundCanvas() {\r\n  return (\r\n    <div className=\"absolute inset-0 w-full h-full pointer-events-none z-0 mix-blend-screen opacity-50 dark:opacity-30\">\r\n      <Canvas camera={{ position: [0, 0, 5], fov: 60 }} dpr={[1, 2]}>\r\n        <Particles />\r\n      </Canvas>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\protfolio\\portfolio\\src\\components\\canvas\\Scene.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\protfolio\\portfolio\\src\\constants.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\protfolio\\portfolio\\src\\lib\\utils.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\protfolio\\portfolio\\src\\main.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\protfolio\\portfolio\\vite.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
